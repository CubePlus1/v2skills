# FavToSkill 环境变量配置
# 复制本文件为 .env.local 并填入真实值

# ─── Phase 1 Demo（无需填写，mock 模式自动生效）───────────────────────
# 不填写 OPENAI_API_KEY 时，所有 AI 接口使用 mock 回复，无需任何 API key

# ─── Phase 2 RAG 对话（填写后自动启用真实 AI）────────────────────────
# OpenAI API Key：用于 embedding（text-embedding-3-small）和对话（gpt-4o-mini）
OPENAI_API_KEY=

# Chroma 向量库路径（本地运行时使用）
CHROMA_DB_PATH=./chroma_db

# ─── Phase 3 生产环境（按需填写）─────────────────────────────────────
# Supabase（向量库 + 关系数据库 + Auth）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
