# FavToSkill 环境变量配置
# 复制本文件为 .env.local 并填入真实值

# ─── AI 接口（生成/分类 Skill 必填）─────────────────────────
# 走 OpenAI 兼容协议，默认指向阿里云百炼（DashScope）的通义千问
# 推荐：DashScope → coding.dashscope.aliyuncs.com/v1 + qwen3.5-plus
# 也可：OpenAI / OpenRouter / 本地 Ollama（base URL 改成 http://localhost:11434/v1）
AI_API_KEY=
AI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
AI_MODEL=qwen3.5-plus

# ─── Phase B（视频抓取）所需，按需填写 ─────────────────────
# Bilibili 可选登录凭证（会员 / 付费内容需要）
# 从浏览器 devtools → Application → Cookies 里拷 SESSDATA 的值
# BILIBILI_COOKIES=
